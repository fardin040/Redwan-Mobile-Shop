{
  "name": "redwan-mobile-shop-worker",
  "version": "2.0.0",
  "description": "Cloudflare Workers backend — 100% on Cloudflare (D1 + KV + Workers)",
  "private": true,
  "scripts": {
    "dev":        "wrangler dev --local",
    "deploy":     "wrangler deploy",
    "tail":       "wrangler tail",
    "db:create":  "wrangler d1 create redwan-mobile-shop-db",
    "db:migrate": "wrangler d1 execute redwan-mobile-shop-db --file=database/schema.sql",
    "db:migrate:local": "wrangler d1 execute redwan-mobile-shop-db --local --file=database/schema.sql",
    "db:seed":    "wrangler d1 execute redwan-mobile-shop-db --file=database/seed.sql",
    "db:studio":  "wrangler d1 studio redwan-mobile-shop-db",
    "kv:create":  "wrangler kv:namespace create"
  },
  "dependencies": {
    "hono":     "^4.2.0",
    "jose":     "^5.2.4",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "wrangler": "^3.50.0"
  }
}
