# ============================================================
# Redwan Mobile Shop — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_NAME=Redwan Mobile Shop
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://redwanmobile.com

# ── PostgreSQL Database ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=redwan_shop
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_SSL=false
# For production (e.g. Railway, Supabase, Neon):
# DATABASE_URL=postgresql://user:password@host:5432/redwan_shop

# ── Redis (for sessions, cache, cart) ────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# For production (Upstash, Redis Cloud):
# REDIS_URL=redis://default:password@host:6379

# ── JWT Auth ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_key_minimum_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another_very_long_random_refresh_secret_key_here
JWT_REFRESH_EXPIRES_IN=30d

# ── bKash Payment Gateway ────────────────────────────────────
BKASH_APP_KEY=your_bkash_app_key
BKASH_APP_SECRET=your_bkash_app_secret
BKASH_USERNAME=your_bkash_username
BKASH_PASSWORD=your_bkash_password
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
# Production: https://tokenized.pay.bka.sh/v1.2.0-beta

# ── Nagad Payment Gateway ─────────────────────────────────────
NAGAD_MERCHANT_ID=your_nagad_merchant_id
NAGAD_MERCHANT_PRIVATE_KEY=your_nagad_private_key
NAGAD_PUBLIC_KEY=nagad_public_key
NAGAD_BASE_URL=http://sandbox.mynagad.com:10080/remote-payment-gateway-1.0

# ── SSLCommerz (Visa/MasterCard) ─────────────────────────────
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASS=your_store_password
SSLCOMMERZ_IS_LIVE=false
# Set to true in production

# ── Cloudinary (Image Storage) ───────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_FOLDER=redwan-mobile-shop

# ── SMS Gateway (Twilio or BD local) ─────────────────────────
SMS_PROVIDER=twilio
# Twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# OR: BulkSMS BD
BULKSMS_API_KEY=your_bulksms_key
BULKSMS_SENDER_ID=REDWAN

# ── Email (Nodemailer) ────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=noreply@redwanmobile.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=Redwan Mobile Shop <noreply@redwanmobile.com>

# ── Pathao Courier API ───────────────────────────────────────
PATHAO_CLIENT_ID=your_pathao_client_id
PATHAO_CLIENT_SECRET=your_pathao_client_secret
PATHAO_BASE_URL=https://hermes.pathao.com/aladdin/api/v1
# Sandbox: https://hermes-sandbox.pathao.com/aladdin/api/v1

# ── Steadfast Courier ────────────────────────────────────────
STEADFAST_API_KEY=your_steadfast_api_key
STEADFAST_SECRET_KEY=your_steadfast_secret
STEADFAST_BASE_URL=https://portal.packzy.com/api/v1

# ── Admin ─────────────────────────────────────────────────────
ADMIN_EMAIL=admin@redwanmobile.com
ADMIN_DEFAULT_PASSWORD=change_this_immediately

# ── Misc ─────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=10
MAX_FILE_SIZE_MB=5
LOW_STOCK_THRESHOLD=10
