# ============================================================
# Redwan Mobile Shop — Environment Variables (Development)
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_NAME=Redwan Mobile Shop
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── PostgreSQL Database ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=redwan_shop
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# ── Redis (for sessions, cache, cart) ────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT Auth ─────────────────────────────────────────────────
JWT_SECRET=dev_secret_key_change_in_production_minimum_64_chars_required_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=dev_refresh_key_change_in_production_minimum_64_chars_required_here
JWT_REFRESH_EXPIRES_IN=30d

# ── bKash Payment Gateway ────────────────────────────────────
BKASH_APP_KEY=sandbox_key
BKASH_APP_SECRET=sandbox_secret
BKASH_USERNAME=sandbox_user
BKASH_PASSWORD=sandbox_pass
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta

# ── Nagad Payment Gateway ─────────────────────────────────────
NAGAD_MERCHANT_ID=test_merchant
NAGAD_MERCHANT_PRIVATE_KEY=test_key
NAGAD_PUBLIC_KEY=test_public_key
NAGAD_BASE_URL=http://sandbox.mynagad.com:10080/remote-payment-gateway-1.0

# ── Twilio SMS ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=test_sid
TWILIO_AUTH_TOKEN=test_token
TWILIO_PHONE_NUMBER=+1234567890

# ── Email (Nodemailer) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SENDER_EMAIL=noreply@redwanmobile.com

# ── Cloudinary ────────────────────────────────────────────────
CLOUDINARY_NAME=test
CLOUDINARY_API_KEY=test
CLOUDINARY_API_SECRET=test

# ── Courier APIs (Pathao, Steadfast) ──────────────────────────
PATHAO_API_KEY=test_key
STEADFAST_API_KEY=test_key
